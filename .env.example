# QiYu / 栖语
# Copy this file to .env and fill in the values you need.

# --------------------------------------
# Basic app settings
# --------------------------------------

ASSISTANT_NAME=XiaoXue
ASSISTANT_HAS_OWN_NUMBER=false
TZ=Asia/Shanghai

# --------------------------------------
# Model selection
# --------------------------------------
# Priority:
# 1. AGENT_MODEL
# 2. OPENAI_MODEL / ANTHROPIC_MODEL
# 3. Built-in fallback

AGENT_MODEL=

# --------------------------------------
# OpenAI-compatible provider
# --------------------------------------
# Fill these if you use an OpenAI-compatible API.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o

# --------------------------------------
# Anthropic-compatible provider
# --------------------------------------
# Fill these if you use an Anthropic-compatible API.
# You can use either an API key or an OAuth token.

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_AUTH_TOKEN=

# --------------------------------------
# Weather API
# --------------------------------------
# Weather is optional.
# If WEATHER_BASE_URL is empty, weather lookup is disabled.
# WEATHER_API_KEY is optional and only needed if your provider requires it.

WEATHER_BASE_URL=
WEATHER_API_KEY=
WEATHER_AUTH_PARAM=key
WEATHER_LOCATION_PARAM=city
WEATHER_ADCODE_PARAM=adcode
