# 雪语示例配置
# 复制本文件为 .env 后，按需填写。

# --------------------------------------
# 基础配置
# --------------------------------------

ASSISTANT_NAME=XiaoXue
ASSISTANT_HAS_OWN_NUMBER=false
TZ=Asia/Shanghai

# 人格选择：xiaoxue=小雪，chuxue=初雪
COMPANION_PERSONA=xiaoxue

# 模型名称优先级：
# 1. AGENT_MODEL
# 2. OPENAI_MODEL / ANTHROPIC_MODEL
AGENT_MODEL=

# --------------------------------------
# OpenAI 兼容接口
# --------------------------------------

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o

# --------------------------------------
# Anthropic 兼容接口
# --------------------------------------

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_AUTH_TOKEN=

# --------------------------------------
# 天气接口（可选）
# --------------------------------------
# 只有配置了天气接口，且记忆里知道用户位置时，才会查询天气。

WEATHER_BASE_URL=
WEATHER_API_KEY=
WEATHER_AUTH_PARAM=key
WEATHER_LOCATION_PARAM=city
WEATHER_ADCODE_PARAM=adcode
