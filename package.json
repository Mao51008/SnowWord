{
  "name": "qiyu-companion",
  "version": "1.2.21",
  "description": "QiYu is a WeChat AI companion runtime with memory, reminders, proactive messaging, and weather-aware extensions.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "node -e \"console.log('No tests configured')\"",
    "test:watch": "node -e \"console.log('No tests configured')\"",
    "login": "tsx src/cli.ts login",
    "accounts": "tsx src/cli.ts list",
    "account:remove": "tsx src/cli.ts remove",
    "state": "tsx src/cli.ts state"
  },
  "dependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "openai": "^6.32.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
